# ============================================
# QUANTUM FIT - Variables de Entorno
# ============================================

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL (connection_limit para pool en producción)
DATABASE_URL="postgresql://quantumfit:password123@localhost:5432/quantumfit?schema=public&connection_limit=10"

# JWT - Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="cambia-esto-por-un-secreto-unico-y-largo-en-produccion"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="cambia-esto-por-otro-secreto-unico-en-produccion"
REFRESH_TOKEN_EXPIRES_IN="7d"
RESET_TOKEN_SECRET="cambia-esto-por-un-secreto-unico-para-reset-password"

# CORS (orígenes permitidos - separados por coma, REQUERIDO en producción)
ALLOWED_ORIGINS="http://localhost:8081,http://localhost:19006,exp://192.168.1.XX:8081,http://localhost:5173"

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Geofencing (radio en metros para check-in automático)
GEOFENCE_RADIUS_METERS=50

# API Key para integración con software externo
INTEGRATION_API_KEY="cambia-esto-por-una-clave-unica-en-produccion"

# Notificaciones Push (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Email (SMTP - compatible con Gmail, Outlook, cualquier proveedor)
# Para Gmail: activar verificación en 2 pasos y generar contraseña de aplicación
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=quantumfit.gym@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx (contraseña de aplicación)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@quantumfit.com

# ============================================================================
# INTEGRACIÓN EXTERNA (Crystal MiFit)
# ============================================================================

# URL de la API externa (Crystal Desarrollo S.R.L.)
EXTERNAL_API_URL=https://crystal.getmifit.app

# Token de acceso para la API externa (PULL - QuantumFit consulta datos)
EXTERNAL_API_TOKEN=

# Credenciales de Crystal para autenticación (login al sistema externo)
EXTERNAL_USER_EMAIL=
EXTERNAL_USER_PASSWORD=

# ============================================================================
# MERCADOPAGO
# ============================================================================

# Access Token de MercadoPago (TEST-xxx para sandbox, APP_USR-xxx para producción)
MERCADOPAGO_ACCESS_TOKEN=

# URL pública donde MP enviará las notificaciones de pago (webhook)
# Ej: https://tu-backend.railway.app/api/mercadopago/webhook
MERCADOPAGO_NOTIFICATION_URL=

# URLs de redirección post-pago (deep links para la app)
MERCADOPAGO_SUCCESS_URL=quantumfit://payment/success
MERCADOPAGO_FAILURE_URL=quantumfit://payment/failure
MERCADOPAGO_PENDING_URL=quantumfit://payment/pending
