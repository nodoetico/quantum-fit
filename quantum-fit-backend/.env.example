PORT=3000
NODE_ENV=production

DATABASE_URL="postgresql://user:password@host:5432/quantumfit?schema=public"

JWT_SECRET="change-me-to-a-random-string"
JWT_EXPIRES_IN="15m"
REFRESH_TOKEN_SECRET="change-me-to-a-random-string"
REFRESH_TOKEN_EXPIRES_IN="7d"
RESET_TOKEN_SECRET="change-me-to-a-random-string"

ALLOWED_ORIGINS="https://your-landing-domain.com,https://your-admin-domain.com"

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

GEOFENCE_RADIUS_METERS=50

INTEGRATION_API_KEY="your-integration-api-key"

EXTERNAL_API_URL=https://crystal.getmifit.app
EXTERNAL_API_TOKEN=your-external-api-token
EXTERNAL_USER_EMAIL=your-email
EXTERNAL_USER_PASSWORD=your-password

MERCADOPAGO_ACCESS_TOKEN=your-mercadopago-access-token
MERCADOPAGO_NOTIFICATION_URL=https://your-domain.com/api/mercadopago/webhook
MERCADOPAGO_SUCCESS_URL=quantumfit://payment/success
MERCADOPAGO_FAILURE_URL=quantumfit://payment/failure
MERCADOPAGO_PENDING_URL=quantumfit://payment/pending

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@gmail.com
